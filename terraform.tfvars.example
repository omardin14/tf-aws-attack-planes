# terraform.tfvars.example
#
# Copy this to terraform.tfvars and edit — `*.tfvars` is gitignored so your real
# values never get committed:
#
#   cp terraform.tfvars.example terraform.tfvars
#
# Every variable has a default, so a bare `terraform apply` also works. The one
# you most likely want to set is `alert_email` (otherwise you only see alarms in
# the console, no email).
#
# WARNING: applying this stands up a deliberately-attackable estate and fires a
# simulated attack against your own account. Use a throwaway sandbox account only.

# Home region for the trail. Keep us-east-1 so global-service events (IAM, STS)
# land here.
region = "us-east-1"

# Prefix applied to every named resource so the whole demo is easy to find and
# tear down.
name_prefix = "atkplane"

# Email subscribed to the SNS alert topic. Leave empty ("") to skip the
# subscription — you'll still see alarms in the console, just no email.
# Confirm the subscription in your inbox after apply.
alert_email = "you@example.com"

# If true, the attack Lambda is invoked automatically on apply. Set false to
# stand up the estate and fire the attack yourself later.
auto_fire = true

# Stand up the GuardDuty detector and wire its findings into the detect/respond
# pipeline (EventBridge -> SNS + auto-quarantine Lambda).
#
# GuardDuty is NOT part of the AWS Free Tier, so this defaults to false. Set it
# to true only on an account where you're happy to pay for GuardDuty.
#
# With it false you still get the full trigger -> detect -> investigate loop: the
# CloudTrail metric-filter alarms fire off the attack's own signal. Only the
# GuardDuty-driven auto-quarantine is skipped (you can still invoke the quarantine
# Lambda by hand to demo the response step).
enable_guardduty = false

# Which scenarios (planes) to deploy. Each is a self-contained slice wired to the
# shared foundation.
#
# Scenario 1 (account takeover / control plane) is on by default: it's the
# reference scenario and cheap - no compute, just IAM + CloudTrail alarms.
scenario_01_enabled = true

# Scenario 2 (compromised workload / network plane) is OFF by default because it
# stands up a VPC + a t3.micro EC2 instance (a small ongoing cost, unlike the
# Free-Tier-shaped Scenario 1). Set it to true on a sandbox to exercise the
# VPC Flow Logs egress/lateral-movement loop.
scenario_02_enabled = false
